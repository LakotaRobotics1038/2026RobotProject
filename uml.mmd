    - farHood : Hood
    - ShooterHoods()
    + getInstance()$ : ShooterHoods
    + getNearHood() : Hood
    + getFarHood() : Hood
  }

  class Hood {
    <<inner>>
    - servoChannel : ServoChannel
    - pulseRange : ServoChannelConfig.PulseRange
    - Hood(ChannelId,PulseRange,ServoHubConfig)
    + enable() : void
    + setAngle(double) : void
  }

  class Kicker {
