    + nudgeManualShooterRPMForward() : void
    + resetManualShooterRPM() : void
    + nudgeManualShooterHoodAngleBackward() : void
    + nudgeManualShooterHoodAngleForward() : void
    + resetManualShooterHoodAngle() : void
